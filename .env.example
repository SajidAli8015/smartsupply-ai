# ── Database ────────────────────────────────────────────────────────────────
# Local dev: PostgreSQL runs in Docker (docker-compose.dev.yml)
DATABASE_URL=postgresql://smartsupply:smartsupply123@localhost:5432/smartsupply_db

# ── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Redis / Celery ───────────────────────────────────────────────────────────
# Optional in local dev — leave unset or comment out to skip Redis.
# Uncomment when you need background tasks locally.
# REDIS_URL=redis://localhost:6379/0

# ── Payments ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...

# ── Email ───────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....

# ── AWS / S3 ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=smartsupply-assets
